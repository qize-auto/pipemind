# DeepSeek (or any OpenAI-compatible) API key
PIPEMIND_LLM_KEY=sk-your-key-here

# API base URL (default: https://api.deepseek.com/v1)
PIPEMIND_LLM_BASE=https://api.deepseek.com

# Auth Gateway token (for OpenClaw local search integration)
PIPEMIND_AUTH_TOKEN=your-auth-token-here

# IMA Knowledge Base credentials (fallback if Auth Gateway unavailable)
# Get these by: powershell.exe -File "<ima_skill_dir>\get-token.ps1" | ConvertFrom-Json | ConvertTo-Json
IMA_CLIENT_ID=
IMA_API_KEY=
